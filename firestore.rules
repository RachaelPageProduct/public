rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // Returns true when the app is NOT in admin-triggered maintenance mode.
    // The config/app doc is set by the billing kill-switch Cloud Function.
    function notInMaintenance() {
      return !exists(/databases/$(database)/documents/config/app) ||
        get(/databases/$(database)/documents/config/app).data.get('maintenanceMode', false) == false;
    }

    // Returns true when the department write rate limit is satisfied.
    // Limits each department document to at most 1 write per 500ms.
    // resource == null means first-ever write — always allowed.
    function withinRateLimit() {
      return resource == null
        || !('lastWrite' in resource.data)
        || request.time > resource.data.lastWrite + duration.value(500, 'ms');
    }

    // ── App config (maintenance mode flag, etc.) ──────────────────────────────
    match /config/{docId} {
      allow read: if true; // must be readable even when logged out (maintenance check)
      allow write: if request.auth != null
        && request.auth.token.email == 'artfulydesign@gmail.com';
    }

    // ── Top-level user doc (sharedUsers, grantedLists, plan, displayName…) ───
    // Any logged-in user can read (needed for invite acceptance to find listAccess).
    // Only the user themselves can write.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── List metadata ─────────────────────────────────────────────────────────
    match /users/{ownerId}/lists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;
      // Any logged-in user can read list metadata (needed for invite acceptance flow)
      allow read: if request.auth != null;
      // Any logged-in user can add themselves to sharedWithUids (invite acceptance only)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWithUids'])
        && request.auth.uid in request.resource.data.sharedWithUids;
    }

    // ── Departments ───────────────────────────────────────────────────────────
    // Owner has full access. Shared users (in sharedWithUids) can read/write.
    // Abuse protections applied to ALL writes:
    //   • notInMaintenance() — blocks all writes when kill switch is active
    //   • withinRateLimit()  — max 1 write per 500ms per department document
    //   • items size cap     — hard limit of 300 items per department
    match /users/{ownerId}/lists/{listId}/departments/{deptId} {
      allow read: if request.auth != null && request.auth.uid == ownerId;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(ownerId)/lists/$(listId)).data.sharedWithUids is list
        && request.auth.uid in get(/databases/$(database)/documents/users/$(ownerId)/lists/$(listId)).data.sharedWithUids;

      allow write: if request.auth != null
        && request.auth.uid == ownerId
        && notInMaintenance()
        && withinRateLimit()
        && (!('items' in request.resource.data) || request.resource.data.items.size() <= 300);

      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(ownerId)/lists/$(listId)).data.sharedWithUids is list
        && request.auth.uid in get(/databases/$(database)/documents/users/$(ownerId)/lists/$(listId)).data.sharedWithUids
        && notInMaintenance()
        && withinRateLimit()
        && (!('items' in request.resource.data) || request.resource.data.items.size() <= 300);
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    // Public read (inviteId is a secret random token), auth required to write
    match /invitations/{inviteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Mail (Trigger Email extension) ────────────────────────────────────────
    match /mail/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Feedback ─────────────────────────────────────────────────────────────
    match /feedback/{docId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null
        && request.auth.token.email == 'artfulydesign@gmail.com';
    }

    // ── Plan overrides ────────────────────────────────────────────────────────
    match /planOverrides/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'artfulydesign@gmail.com';
    }
  }
}
